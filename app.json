{
  "expo": {
    "name": "Vibesfilm",
    "slug": "movies_emotion",
    "version": "2.0.0",
    "scheme": "vibesfilm",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vibesfilm.app",
      "buildNumber": "5",
      "infoPlist": {
        "NSCameraUsageDescription": "O Vibesfilm não usa a câmera.",
        "NSPhotoLibraryUsageDescription": "O Vibesfilm não acessa sua galeria de fotos.",
        "NSMicrophoneUsageDescription": "O Vibesfilm não usa o microfone.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.vibesfilm.app",
      "versionCode": 8,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.vibesfilm.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "6d4cc61a-d879-4504-98a0-01b48bbac289"
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true,
            "jsEngine": "jsc"
          }
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6d4cc61a-d879-4504-98a0-01b48bbac289",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    }
  }
}